// Attendance Bot Configuration File
// Copy this file to config.hpp (remove the .example extension)
//
// This file supports INI-style format: key = value
// Comments can use // or #
//
// Priority: This file is checked FIRST, then environment variables

// ============================================================================
// API Configuration
// ============================================================================

// Your bot API token (Bearer token)
// Get this from your bot administration panel
apiToken = your_bot_api_token_here

// The endpoint URL for the API
// Example: https://your-bot-api.com/api/bot/events
endpoint = https://your-bot-api.com/api/bot/events

// ============================================================================
// Alternative key names (all supported)
// ============================================================================
// token = your_bot_api_token_here
// url = https://your-bot-api.com/api/bot/events
// BOT_API_TOKEN = your_bot_api_token_here
// BOT_API_ENDPOINT = https://your-bot-api.com/api/bot/events

// ============================================================================
// Notes:
// - After changing this file, use: callExtension "reloadConfig"
// - Or restart the server
// - Environment variables still work as fallback
// - Both config file and env vars can be used
